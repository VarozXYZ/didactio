PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=didactio
LOG_LEVEL=info
LOG_FILE_PATH=

AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1/ai

AI_CHEAP_PROVIDER=deepseek
AI_CHEAP_MODEL=deepseek-v3.2

AI_PREMIUM_PROVIDER=deepseek
AI_PREMIUM_MODEL=deepseek-v3.2-thinking

AI_AUTHORING_LANGUAGE=English
AI_AUTHORING_TONE=neutral
AI_AUTHORING_LEARNER_LEVEL=beginner
AI_EXTRA_INSTRUCTIONS=

CORS_ALLOWED_ORIGINS=http://localhost:5173
TRUST_PROXY=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
COOKIE_SECRET=replace-with-a-third-long-random-secret
JWT_ISSUER=didactio
JWT_AUDIENCE=web
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600

AUTH_ALLOWED_REDIRECTS=http://localhost:5173/auth/callback
AUTH_DEFAULT_REDIRECT=http://localhost:5173/auth/callback
AUTH_ADMIN_EMAILS=admin@example.com

AUTH_COOKIE_NAME=refresh_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_PACK=
STRIPE_PRICE_CREATOR_PACK=
STRIPE_PRICE_TEACHER_MONTHLY=
STRIPE_PRICE_TEACHER_PRO_MONTHLY=
